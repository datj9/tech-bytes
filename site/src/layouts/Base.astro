---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Release Radar', icon: '📦' },
  { href: '/hn-digest', label: 'HN Digest', icon: '📰' },
  { href: '/trending', label: 'Trending', icon: '🔥' },
  { href: '/search', label: 'Search', icon: '🔍' },
  { href: '/contribute', label: 'Contribute', icon: '💡' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Tech Bytes</title>
    <link rel="alternate" type="application/rss+xml" title="Tech Bytes — Release Radar" href="/rss/releases.xml" />
    <link rel="alternate" type="application/rss+xml" title="Tech Bytes — HN Daily Digest" href="/rss/hn.xml" />
    <link rel="alternate" type="application/rss+xml" title="Tech Bytes — GitHub Trending" href="/rss/trending.xml" />
  </head>
  <body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col font-sans antialiased">
    <header class="border-b border-slate-800 sticky top-0 bg-slate-900/95 backdrop-blur-sm z-50">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-emerald-400 hover:text-emerald-300 transition-colors">
          <span class="text-2xl">⚡</span>
          <span>Tech Bytes</span>
        </a>
        <nav class="flex items-center gap-1 sm:gap-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'bg-slate-800 text-emerald-400'
                  : 'text-slate-400 hover:text-slate-100 hover:bg-slate-800/50',
              ]}
            >
              <span class="hidden sm:inline me-1">{link.icon}</span>
              {link.label}
            </a>
          ))}
          <a
            href="/rss/releases.xml"
            class="px-2 py-2 rounded-lg text-slate-400 hover:text-orange-400 hover:bg-slate-800/50 transition-colors ms-1"
            title="RSS Feeds"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="inline-block">
              <circle cx="6.18" cy="17.82" r="2.18" />
              <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-auto">
      <div class="max-w-5xl mx-auto px-4 py-6 text-center text-sm text-slate-500">
        <p>Updated daily via LLM</p>
        <p class="mt-1 text-slate-600">bytes.finaldivision.com</p>
      </div>
    </footer>
  </body>
</html>
